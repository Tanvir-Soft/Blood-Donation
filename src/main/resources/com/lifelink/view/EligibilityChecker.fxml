<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="20.0" alignment="CENTER" style="-fx-padding: 24; -fx-background-color: transparent;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.lifelink.controller.EligibilityController">
    <!-- CHECKER FORM CARD -->
    <VBox prefWidth="480.0" maxWidth="480.0" spacing="18.0" styleClass="card" stylesheets="@../css/style.css">
        <Label styleClass="card-title" text="Blood Donation Eligibility Checker" />
        <Label text="Enter the donor's details below to verify if they are currently eligible to donate blood." textFill="#757575" wrapText="true" />
        
        <VBox spacing="6.0">
            <Label text="Age (Years) *" />
            <TextField fx:id="ageField" promptText="Must be 18 to 60" />
        </VBox>
        
        <VBox spacing="6.0">
            <Label text="Weight (kg) *" />
            <TextField fx:id="weightField" promptText="Must be at least 50 kg" />
        </VBox>
        
        <VBox spacing="6.0">
            <Label text="Last Donation Date (if any)" />
            <DatePicker fx:id="lastDonationDatePicker" promptText="Select date (leave empty if first-time donor)" maxWidth="Infinity" />
        </VBox>
        
        <HBox spacing="10.0" alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0;">
            <Button onAction="#handleClear" styleClass="btn-secondary" text="Clear" prefWidth="100.0" />
            <Button onAction="#handleCheckEligibility" styleClass="btn-primary" text="Check Eligibility" prefWidth="160.0" />
        </HBox>
    </VBox>

    <!-- STATUS CARD (DYNAMICALLY VISIBLE) -->
    <VBox fx:id="statusCard" prefWidth="480.0" maxWidth="480.0" spacing="10.0" visible="false" managed="false" style="-fx-padding: 20px; -fx-background-radius: 12px; -fx-border-width: 1px; -fx-border-radius: 12px;" stylesheets="@../css/style.css">
        <Label fx:id="statusHeader" text="ELIGIBILITY STATUS">
            <font><Font name="System Bold" size="14.0" /></font>
        </Label>
        <Label fx:id="statusReason" text="Details will appear here." wrapText="true">
            <font><Font size="13.0" /></font>
        </Label>
    </VBox>
</VBox>
