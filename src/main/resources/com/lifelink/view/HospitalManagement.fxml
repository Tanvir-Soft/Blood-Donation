<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<HBox spacing="20.0" style="-fx-padding: 0 0 20 0;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.lifelink.controller.HospitalController">
    <!-- LEFT SIDE: FORM CARD -->
    <VBox prefWidth="340.0" spacing="16.0" styleClass="card" stylesheets="@../css/style.css">
        <Label styleClass="card-title" text="Hospital Profile" />
        
        <VBox spacing="6.0">
            <Label text="Hospital Name *" />
            <TextField fx:id="nameField" promptText="Enter hospital name" />
        </VBox>
        
        <VBox spacing="6.0">
            <Label text="Address *" />
            <TextField fx:id="addressField" promptText="e.g. 456 Healthcare Blvd" />
        </VBox>
        
        <VBox spacing="6.0">
            <Label text="Contact Number *" />
            <TextField fx:id="contactField" promptText="Phone Number" />
        </VBox>
        
        <VBox spacing="6.0">
            <Label text="Email Address *" />
            <TextField fx:id="emailField" promptText="name@hospital.org" />
        </VBox>
        
        <HBox spacing="10.0" style="-fx-padding: 10 0 0 0;">
            <Button fx:id="addButton" onAction="#handleAddHospital" styleClass="btn-success" text="Add Hospital" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
            <Button fx:id="updateButton" onAction="#handleUpdateHospital" styleClass="btn-primary" text="Update" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
        </HBox>
        <HBox spacing="10.0">
            <Button fx:id="deleteButton" onAction="#handleDeleteHospital" styleClass="btn-danger" text="Delete" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
            <Button fx:id="clearButton" onAction="#handleClearForm" styleClass="btn-secondary" text="Clear" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
        </HBox>
    </VBox>
    
    <!-- RIGHT SIDE: TABLE VIEW -->
    <VBox spacing="16.0" styleClass="card" HBox.hgrow="ALWAYS" stylesheets="@../css/style.css">
        <HBox alignment="CENTER_LEFT" spacing="12.0">
            <Label styleClass="card-title" text="All Registered Hospitals" HBox.hgrow="ALWAYS" />
            <TextField fx:id="searchField" promptText="🔍 Search hospitals by name or address..." prefWidth="280.0" />
            <Button onAction="#handleRefresh" styleClass="btn-secondary" text="Refresh" />
        </HBox>
        
        <TableView fx:id="hospitalTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="60.0" />
                <TableColumn fx:id="colName" text="Hospital Name" prefWidth="180.0" />
                <TableColumn fx:id="colAddress" text="Address" prefWidth="220.0" />
                <TableColumn fx:id="colContact" text="Contact" prefWidth="120.0" />
                <TableColumn fx:id="colEmail" text="Email" prefWidth="180.0" />
            </columns>
        </TableView>
    </VBox>
</HBox>
