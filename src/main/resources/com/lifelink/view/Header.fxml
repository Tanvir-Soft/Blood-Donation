<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<HBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      alignment="CENTER_LEFT" prefHeight="64.0" spacing="0.0"
      style="-fx-background-color: white; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 4, 0, 0, 2); -fx-padding: 0 24 0 24;">

    <!-- Page Title -->
    <VBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
        <Label text="Page Title" textFill="#1A1D23">
            <font><Font name="System Bold" size="18.0"/></font>
        </Label>
        <Label text="LifeLink › Subtitle" textFill="#9E9E9E">
            <font><Font size="11.0"/></font>
        </Label>
    </VBox>

    <!-- User Info Area -->
    <HBox alignment="CENTER" spacing="12.0">
        <StackPane prefWidth="38.0" prefHeight="38.0" style="-fx-background-color: #E53935; -fx-background-radius: 19;">
            <Label text="U" textFill="white">
                <font><Font name="System Bold" size="15.0"/></font>
            </Label>
        </StackPane>
        <VBox alignment="CENTER_LEFT">
            <Label text="User Name" textFill="#212121">
                <font><Font name="System Bold" size="12.0"/></font>
            </Label>
            <Label text="USER ROLE" textFill="#E53935">
                <font><Font size="10.0"/></font>
            </Label>
        </VBox>
    </HBox>
</HBox>
