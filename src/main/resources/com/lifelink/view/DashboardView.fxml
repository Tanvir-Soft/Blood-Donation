<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.lifelink.controller.DashboardController"
            prefWidth="1200.0" prefHeight="720.0"
            style="-fx-background-color: #F0F2F5;">

    <!-- ============================================================ -->
    <!--  LEFT SIDEBAR                                                 -->
    <!-- ============================================================ -->
    <left>
        <VBox prefWidth="230.0" minWidth="230.0"
              style="-fx-background-color: #1A1D23; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 8, 0, 2, 0);">

            <!-- Brand Logo Area -->
            <VBox alignment="CENTER" prefHeight="90.0"
                  style="-fx-background-color: #E53935; -fx-padding: 0;">
                <HBox alignment="CENTER" spacing="10.0">
                    <ImageView fitWidth="32.0" fitHeight="32.0" preserveRatio="true">
                        <Image url="@../assets/logo.png"/>
                    </ImageView>
                    <Label text="LifeLink" textFill="white">
                        <font><Font name="System Bold" size="22.0"/></font>
                    </Label>
                </HBox>
                <Label fx:id="userRoleLabel" text="System Dashboard" textFill="#FFCDD2">
                    <font><Font size="10.0"/></font>
                </Label>
            </VBox>

            <!-- Navigation Menu (scrollable) -->
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="NEVER"
                        style="-fx-background: transparent; -fx-background-color: transparent;"
                        VBox.vgrow="ALWAYS">
                <VBox spacing="2.0" style="-fx-padding: 16 10 10 10;">

                    <Label text="MAIN MENU" textFill="#5C6370">
                        <font><Font name="System Bold" size="9.0"/></font>
                        <VBox.margin><Insets bottom="6.0"/></VBox.margin>
                    </Label>

                    <!-- Dashboard -->
                    <Button fx:id="navDashboard" text="📊  Dashboard" maxWidth="Infinity"
                            onAction="#handleNavDashboard"
                            style="-fx-background-color: #E53935; -fx-text-fill: white;
                                   -fx-font-size: 12; -fx-font-weight: bold; -fx-alignment: CENTER_LEFT;
                                   -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 10 14;">
                        <VBox.margin><Insets bottom="2.0"/></VBox.margin>
                    </Button>

                    <!-- Donors -->
                    <Button fx:id="navDonors" text="🩸  Donors" maxWidth="Infinity"
                            onAction="#handleNavDonors"
                            style="-fx-background-color: transparent; -fx-text-fill: #B0B7C3;
                                   -fx-font-size: 12; -fx-alignment: CENTER_LEFT;
                                   -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 10 14;">
                        <VBox.margin><Insets bottom="2.0"/></VBox.margin>
                    </Button>

                    <!-- Search Blood -->
                    <Button fx:id="navSearch" text="🔍  Search Blood" maxWidth="Infinity"
                            onAction="#handleNavSearch"
                            style="-fx-background-color: transparent; -fx-text-fill: #B0B7C3;
                                   -fx-font-size: 12; -fx-alignment: CENTER_LEFT;
                                   -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 10 14;">
                        <VBox.margin><Insets bottom="2.0"/></VBox.margin>
                    </Button>

                    <!-- Requests -->
                    <Button fx:id="navRequests" text="📋  Requests" maxWidth="Infinity"
                            onAction="#handleNavRequests"
                            style="-fx-background-color: transparent; -fx-text-fill: #B0B7C3;
                                   -fx-font-size: 12; -fx-alignment: CENTER_LEFT;
                                   -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 10 14;">
                        <VBox.margin><Insets bottom="2.0"/></VBox.margin>
                    </Button>

                    <!-- Hospitals -->
                    <Button fx:id="navHospitals" text="🏥  Hospitals" maxWidth="Infinity"
                            onAction="#handleNavHospitals"
                            style="-fx-background-color: transparent; -fx-text-fill: #B0B7C3;
                                   -fx-font-size: 12; -fx-alignment: CENTER_LEFT;
                                   -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 10 14;">
                        <VBox.margin><Insets bottom="2.0"/></VBox.margin>
                    </Button>

                    <Region prefHeight="6.0"/>
                    <Separator style="-fx-background-color: #2E3340;"/>
                    <Region prefHeight="6.0"/>

                    <Label text="TOOLS" textFill="#5C6370">
                        <font><Font name="System Bold" size="9.0"/></font>
                        <VBox.margin><Insets bottom="6.0"/></VBox.margin>
                    </Label>

                    <!-- Donation History -->
                    <Button fx:id="navHistory" text="📜  Donation History" maxWidth="Infinity"
                            onAction="#handleNavHistory"
                            style="-fx-background-color: transparent; -fx-text-fill: #B0B7C3;
                                   -fx-font-size: 12; -fx-alignment: CENTER_LEFT;
                                   -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 10 14;">
                        <VBox.margin><Insets bottom="2.0"/></VBox.margin>
                    </Button>

                    <!-- Eligibility Checker -->
                    <Button fx:id="navEligibility" text="✅  Eligibility Checker" maxWidth="Infinity"
                            onAction="#handleNavEligibility"
                            style="-fx-background-color: transparent; -fx-text-fill: #B0B7C3;
                                   -fx-font-size: 12; -fx-alignment: CENTER_LEFT;
                                   -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 10 14;">
                        <VBox.margin><Insets bottom="2.0"/></VBox.margin>
                    </Button>

                    <!-- Blood Stock -->
                    <Button fx:id="navStock" text="🩺  Blood Stock" maxWidth="Infinity"
                            onAction="#handleNavStock"
                            style="-fx-background-color: transparent; -fx-text-fill: #B0B7C3;
                                   -fx-font-size: 12; -fx-alignment: CENTER_LEFT;
                                   -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 10 14;">
                        <VBox.margin><Insets bottom="2.0"/></VBox.margin>
                    </Button>

                </VBox>
            </ScrollPane>

            <!-- Logout Button at Bottom -->
            <VBox style="-fx-padding: 10 10 16 10; -fx-background-color: #141720;">
                <Separator style="-fx-background-color: #2E3340;">
                    <VBox.margin><Insets bottom="10.0"/></VBox.margin>
                </Separator>
                <Button fx:id="navLogout" text="⏻  Logout" maxWidth="Infinity"
                        onAction="#handleLogout"
                        style="-fx-background-color: #2E3340; -fx-text-fill: #EF9A9A;
                               -fx-font-size: 12; -fx-font-weight: bold; -fx-alignment: CENTER_LEFT;
                               -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 10 14;"/>
            </VBox>
        </VBox>
    </left>

    <!-- ============================================================ -->
    <!--  TOP HEADER                                                   -->
    <!-- ============================================================ -->
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="64.0" spacing="0.0"
              style="-fx-background-color: white;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 4, 0, 0, 2);
                     -fx-padding: 0 24 0 24;">

            <!-- Page Title -->
            <VBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                <Label fx:id="pageTitle" text="Dashboard" textFill="#1A1D23">
                    <font><Font name="System Bold" size="18.0"/></font>
                </Label>
                <Label fx:id="pageBreadcrumb" text="LifeLink › Dashboard" textFill="#9E9E9E">
                    <font><Font size="11.0"/></font>
                </Label>
            </VBox>

            <!-- Right: User Info -->
            <HBox alignment="CENTER" spacing="12.0">
                <!-- User Avatar Circle -->
                <StackPane prefWidth="38.0" prefHeight="38.0"
                           style="-fx-background-color: #E53935; -fx-background-radius: 19;">
                    <Label fx:id="userInitialLabel" text="A" textFill="white">
                        <font><Font name="System Bold" size="15.0"/></font>
                    </Label>
                </StackPane>
                <VBox alignment="CENTER_LEFT">
                    <Label fx:id="userNameLabel" text="Admin User" textFill="#212121">
                        <font><Font name="System Bold" size="12.0"/></font>
                    </Label>
                    <Label fx:id="userRoleHeaderLabel" text="ADMIN" textFill="#E53935">
                        <font><Font size="10.0"/></font>
                    </Label>
                </VBox>
            </HBox>
        </HBox>
    </top>

    <!-- ============================================================ -->
    <!--  CENTER CONTENT AREA                                          -->
    <!-- ============================================================ -->
    <center>
        <!-- This StackPane will swap content panes when sidebar items are clicked -->
        <StackPane fx:id="contentArea" style="-fx-padding: 24;">
            <!-- Default content loaded by DashboardController.initialize() -->
        </StackPane>
    </center>

</BorderPane>
