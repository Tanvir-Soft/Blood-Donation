<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="20.0" style="-fx-padding: 0 0 20 0;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.lifelink.controller.BloodSearchController">
    <!-- FILTER BAR CARD -->
    <VBox spacing="12.0" styleClass="card" stylesheets="@../css/style.css">
        <Label styleClass="card-title" text="Filter Donors" />
        <HBox spacing="16.0" alignment="BOTTOM_LEFT">
            <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                <Label text="Blood Group" />
                <ComboBox fx:id="bloodGroupCombo" promptText="Select Group" maxWidth="Infinity" />
            </VBox>
            
            <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                <Label text="City" />
                <TextField fx:id="cityField" promptText="e.g. Chicago" />
            </VBox>
            
            <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                <Label text="Availability Status" />
                <ComboBox fx:id="availabilityCombo" promptText="Any" maxWidth="Infinity" />
            </VBox>
            
            <HBox spacing="10.0">
                <Button onAction="#handleSearch" styleClass="btn-primary" text="Search" prefWidth="100.0" />
                <Button onAction="#handleClearFilters" styleClass="btn-secondary" text="Clear" prefWidth="90.0" />
            </HBox>
        </HBox>
    </VBox>

    <!-- SEARCH RESULTS CARD -->
    <VBox spacing="16.0" styleClass="card" VBox.vgrow="ALWAYS" stylesheets="@../css/style.css">
        <Label styleClass="card-title" text="Matches Found" />
        
        <TableView fx:id="resultsTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colName" text="Donor Name" prefWidth="200.0" />
                <TableColumn fx:id="colBloodGroup" text="Blood Group" prefWidth="120.0" />
                <TableColumn fx:id="colCity" text="City" prefWidth="150.0" />
                <TableColumn fx:id="colContact" text="Contact Email" prefWidth="250.0" />
                <TableColumn fx:id="colAvailability" text="Availability" prefWidth="150.0" />
            </columns>
        </TableView>
    </VBox>
</VBox>
