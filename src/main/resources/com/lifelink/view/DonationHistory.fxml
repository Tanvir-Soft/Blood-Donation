<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<HBox spacing="20.0" style="-fx-padding: 0 0 20 0;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.lifelink.controller.DonationHistoryController">
    <!-- LEFT SIDE: LOG DONATION -->
    <VBox prefWidth="340.0" spacing="16.0" styleClass="card" stylesheets="@../css/style.css">
        <Label styleClass="card-title" text="Log New Donation" />
        <Label text="Log a successful blood donation to increment stock levels and update donor eligibility." textFill="#757575" wrapText="true">
            <font><Font size="12.0" /></font>
        </Label>
        
        <VBox spacing="6.0">
            <Label text="Select Donor *" />
            <ComboBox fx:id="donorCombo" promptText="Select Donor" maxWidth="Infinity" />
        </VBox>
        
        <VBox spacing="6.0">
            <Label text="Donation Location *" />
            <TextField fx:id="locationField" promptText="e.g. St. Mary Blood Bank" />
        </VBox>
        
        <HBox spacing="12.0">
            <VBox HBox.hgrow="ALWAYS" spacing="6.0">
                <Label text="Units Donated *" />
                <TextField fx:id="unitsField" promptText="Units" />
            </VBox>
            <VBox HBox.hgrow="ALWAYS" spacing="6.0">
                <Label text="Donation Date *" />
                <DatePicker fx:id="donationDatePicker" promptText="YYYY-MM-DD" maxWidth="Infinity" />
            </VBox>
        </HBox>
        
        <HBox spacing="10.0" style="-fx-padding: 10 0 0 0;">
            <Button fx:id="logButton" onAction="#handleLogDonation" styleClass="btn-success" text="Log Donation" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
            <Button fx:id="clearButton" onAction="#handleClearForm" styleClass="btn-secondary" text="Clear" prefWidth="90.0" />
        </HBox>
    </VBox>
    
    <!-- RIGHT SIDE: TABLE VIEW -->
    <VBox spacing="16.0" styleClass="card" HBox.hgrow="ALWAYS" stylesheets="@../css/style.css">
        <HBox alignment="CENTER_LEFT" spacing="12.0">
            <Label styleClass="card-title" text="Donation Log History" HBox.hgrow="ALWAYS" />
            <TextField fx:id="searchField" promptText="🔍 Search logs by donor or location..." prefWidth="280.0" />
            <Button onAction="#handleRefresh" styleClass="btn-secondary" text="Refresh" />
        </HBox>
        
        <TableView fx:id="historyTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId" text="Log ID" prefWidth="60.0" />
                <TableColumn fx:id="colDonor" text="Donor Name" prefWidth="180.0" />
                <TableColumn fx:id="colBloodGroup" text="Blood Group" prefWidth="100.0" />
                <TableColumn fx:id="colDate" text="Donation Date" prefWidth="120.0" />
                <TableColumn fx:id="colUnits" text="Units" prefWidth="80.0" />
                <TableColumn fx:id="colLocation" text="Location" prefWidth="200.0" />
            </columns>
        </TableView>
    </VBox>
</HBox>
