<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="20.0" alignment="CENTER" style="-fx-padding: 24; -fx-background-color: transparent;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.lifelink.controller.BloodRequestController">
    <!-- SUBMIT REQUEST FORM CARD -->
    <VBox prefWidth="480.0" maxWidth="480.0" spacing="18.0" styleClass="card" stylesheets="@../css/style.css">
        <HBox alignment="CENTER_LEFT" spacing="12.0">
            <Label text="🚨 Submit Emergency Blood Request" textFill="#E53935">
                <font><Font name="System Bold" size="18.0" /></font>
            </Label>
        </HBox>
        
        <Label text="Please fill in details to broadcast an emergency request to the hospital network." textFill="#757575" wrapText="true" />
        
        <VBox spacing="6.0">
            <Label text="Blood Group Required *" />
            <ComboBox fx:id="bloodGroupCombo" promptText="Select Blood Group" maxWidth="Infinity" />
        </VBox>
        
        <VBox spacing="6.0">
            <Label text="Receiving Hospital *" />
            <ComboBox fx:id="hospitalCombo" promptText="Select Hospital" maxWidth="Infinity" />
        </VBox>
        
        <HBox spacing="16.0">
            <VBox HBox.hgrow="ALWAYS" spacing="6.0">
                <Label text="Needed Units *" />
                <TextField fx:id="unitsField" promptText="e.g. 3" />
            </VBox>
            <VBox HBox.hgrow="ALWAYS" spacing="6.0">
                <Label text="Urgency Level *" />
                <ComboBox fx:id="urgencyCombo" promptText="Select Urgency" maxWidth="Infinity" />
            </VBox>
        </HBox>
        
        <VBox spacing="6.0">
            <Label text="Contact Number *" />
            <TextField fx:id="contactField" promptText="Enter contact phone number" />
        </VBox>
        
        <HBox spacing="12.0" style="-fx-padding: 10 0 0 0;" alignment="CENTER_RIGHT">
            <Button fx:id="cancelButton" onAction="#handleCancel" styleClass="btn-secondary" text="Cancel" prefWidth="100.0" />
            <Button fx:id="submitButton" onAction="#handleSubmit" styleClass="btn-primary" text="Submit Request" prefWidth="155.0" />
        </HBox>
    </VBox>
</VBox>
