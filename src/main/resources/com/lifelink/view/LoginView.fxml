<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.geometry.Insets?>

<HBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.lifelink.controller.LoginController"
      prefWidth="900.0" prefHeight="580.0">

    <!-- ===== LEFT BRANDING PANEL ===== -->
    <VBox alignment="CENTER" prefWidth="380.0"
          style="-fx-background-color: linear-gradient(to bottom, #C62828, #E53935, #EF5350);
                 -fx-padding: 50 40 50 40;">

        <!-- Logo Image -->
        <ImageView fitWidth="90.0" fitHeight="90.0" preserveRatio="true">
            <Image url="@../assets/logo.png"/>
        </ImageView>

        <Region prefHeight="20.0"/>

        <Label text="LifeLink" textFill="white">
            <font><Font name="System Bold" size="40.0"/></font>
        </Label>

        <Region prefHeight="8.0"/>

        <Label text="Blood Donation &amp; Emergency Finder" textFill="#FFCDD2" wrapText="true" textAlignment="CENTER" maxWidth="280.0">
            <font><Font size="14.0"/></font>
        </Label>

        <Region prefHeight="40.0"/>

        <!-- Separator Line -->
        <Region prefWidth="60.0" prefHeight="2.0"
                style="-fx-background-color: rgba(255,255,255,0.4);"/>

        <Region prefHeight="30.0"/>

        <Label text="&quot;Every drop counts." textFill="#FFEBEE" wrapText="true" textAlignment="CENTER" maxWidth="280.0">
            <font><Font name="System Italic" size="13.0"/></font>
        </Label>
        <Label text="Be someone's lifeline today.&quot;" textFill="#FFEBEE" wrapText="true" textAlignment="CENTER" maxWidth="280.0">
            <font><Font name="System Italic" size="13.0"/></font>
        </Label>

        <Region prefHeight="40.0"/>

        <!-- Heartbeat icon text decoration -->
        <Label text="❤ Save Lives" textFill="rgba(255,255,255,0.6)">
            <font><Font size="12.0"/></font>
        </Label>
    </VBox>

    <!-- ===== RIGHT FORM PANEL ===== -->
    <StackPane HBox.hgrow="ALWAYS"
               style="-fx-background-color: #FAFAFA;">
        <VBox alignment="CENTER" spacing="0" maxWidth="360.0">
            <VBox.margin><Insets left="20.0" right="20.0"/></VBox.margin>

            <!-- Welcome Header -->
            <Label text="Welcome Back!" textFill="#212121">
                <font><Font name="System Bold" size="28.0"/></font>
            </Label>
            <Region prefHeight="6.0"/>
            <Label text="Sign in to your LifeLink account" textFill="#757575">
                <font><Font size="13.0"/></font>
            </Label>

            <Region prefHeight="36.0"/>

            <!-- Username Field -->
            <Label text="Username" textFill="#424242">
                <font><Font name="System Bold" size="12.0"/></font>
                <VBox.margin><Insets bottom="6.0"/></VBox.margin>
            </Label>
            <TextField fx:id="usernameField" promptText="Enter your username"
                       style="-fx-background-color: white;
                              -fx-border-color: #E0E0E0;
                              -fx-border-radius: 8;
                              -fx-background-radius: 8;
                              -fx-padding: 12 14;
                              -fx-font-size: 13px;
                              -fx-pref-height: 44;"
                       maxWidth="Infinity">
                <VBox.margin><Insets bottom="18.0"/></VBox.margin>
            </TextField>

            <!-- Password Field -->
            <Label text="Password" textFill="#424242">
                <font><Font name="System Bold" size="12.0"/></font>
                <VBox.margin><Insets bottom="6.0"/></VBox.margin>
            </Label>
            <PasswordField fx:id="passwordField" promptText="Enter your password"
                           style="-fx-background-color: white;
                                  -fx-border-color: #E0E0E0;
                                  -fx-border-radius: 8;
                                  -fx-background-radius: 8;
                                  -fx-padding: 12 14;
                                  -fx-font-size: 13px;
                                  -fx-pref-height: 44;"
                           maxWidth="Infinity">
                <VBox.margin><Insets bottom="6.0"/></VBox.margin>
            </PasswordField>

            <!-- Forgot Password -->
            <Hyperlink fx:id="forgotPasswordLink" text="Forgot Password?" textFill="#E53935"
                       style="-fx-border-color: transparent; -fx-font-size: 12;"
                       onAction="#handleForgotPassword">
                <VBox.margin><Insets bottom="26.0" left="-4.0"/></VBox.margin>
            </Hyperlink>

            <!-- Login Button -->
            <Button fx:id="loginButton" text="Sign In" onAction="#handleLogin"
                    maxWidth="Infinity" prefHeight="46.0"
                    style="-fx-background-color: #E53935;
                           -fx-text-fill: white;
                           -fx-font-size: 14px;
                           -fx-font-weight: bold;
                           -fx-background-radius: 8;
                           -fx-cursor: hand;">
                <VBox.margin><Insets bottom="14.0"/></VBox.margin>
            </Button>

            <!-- Divider -->
            <HBox alignment="CENTER" spacing="10.0">
                <VBox.margin><Insets bottom="14.0"/></VBox.margin>
                <Region HBox.hgrow="ALWAYS" prefHeight="1.0"
                        style="-fx-background-color: #E0E0E0;"/>
                <Label text="or" textFill="#9E9E9E">
                    <font><Font size="12.0"/></font>
                </Label>
                <Region HBox.hgrow="ALWAYS" prefHeight="1.0"
                        style="-fx-background-color: #E0E0E0;"/>
            </HBox>

            <!-- Register Button -->
            <Button fx:id="registerButton" text="Create New Account" onAction="#handleRegister"
                    maxWidth="Infinity" prefHeight="44.0"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #E53935;
                           -fx-font-size: 13px;
                           -fx-font-weight: bold;
                           -fx-border-color: #E53935;
                           -fx-border-radius: 8;
                           -fx-background-radius: 8;
                           -fx-cursor: hand;">
                <VBox.margin><Insets bottom="24.0"/></VBox.margin>
            </Button>

            <!-- Footer -->
            <Label text="LifeLink © 2026 — Healthcare Management System"
                   textFill="#BDBDBD" textAlignment="CENTER" wrapText="true">
                <font><Font size="10.0"/></font>
            </Label>
        </VBox>
    </StackPane>

</HBox>
